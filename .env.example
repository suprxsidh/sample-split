# SampleSplit Environment Configuration
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=production

# Database
# SQLite (default for local development):
# DATABASE_URL=sqlite:///samplesplit.db
#
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/samplesplit
#
# PostgreSQL on Railway:
# DATABASE_URL=postgresql+psycopg://username:password@host:port/database
#
# PostgreSQL on Render:
# DATABASE_URL=postgresql+psycopg://username:password@host:port/database?sslmode=require
DATABASE_URL=sqlite:///samplesplit.db

# Admin (change password in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password1234
